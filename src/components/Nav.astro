---
---
<nav id="main-nav" class="fixed top-0 left-0 right-0 z-50 backdrop-blur-xl transition-all duration-300 bg-white/10 border-b border-white/20 shadow-lg shadow-black/5">
  <div class="max-w-6xl mx-auto px-6 h-16 flex items-center justify-between">
    <!-- Logo -->
    <a href="/" class="flex items-center group">
      <img id="logo-dark" src="/brand/hostbase-brand-assets/logos/full-logo/hostbase-logo-full-color-dark.svg" alt="Hostbase" class="h-8 transition-opacity duration-300 group-hover:scale-105" />
      <img id="logo-light" src="/brand/hostbase-brand-assets/logos/full-logo/hostbase-logo-full-color-light.svg" alt="Hostbase" class="h-8 transition-opacity duration-300 group-hover:scale-105 hidden absolute" />
    </a>

    <!-- Desktop Nav -->
    <div class="hidden md:flex items-center gap-8">
      <a href="#features" class="nav-link text-sm transition-colors text-white/70 hover:text-white py-3">Features</a>
      <a href="#pricing" class="nav-link text-sm transition-colors text-white/70 hover:text-white py-3">Pricing</a>
    </div>

    <!-- CTA -->
    <div class="hidden md:flex items-center gap-3">
      <a
        href="#demo"
        id="nav-cta"
        class="inline-flex items-center gap-2 px-5 py-2.5 text-sm font-medium rounded-lg transition-all duration-300 bg-white/15 text-white border border-white/20 hover:bg-white/25 backdrop-blur-sm"
      >
        Request a Demo
        <svg width="14" height="14" viewBox="0 0 16 16" fill="none">
          <path d="M6 3l5 5-5 5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </div>

    <!-- Mobile Menu Button -->
    <button
      id="mobile-menu-btn"
      class="md:hidden p-2 transition-colors text-white/70 hover:text-white"
      aria-label="Toggle menu"
    >
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M4 6h16M4 12h16M4 18h16" stroke-linecap="round"/>
      </svg>
    </button>
  </div>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="md:hidden overflow-hidden transition-all duration-300 ease-in-out max-h-0 opacity-0 border-t border-white/10 bg-white/10 backdrop-blur-xl">
    <div class="px-6 py-4 flex flex-col gap-3">
      <a href="#features" class="mobile-link text-sm py-2 transition-colors text-white/70 hover:text-white">Features</a>
      <a href="#pricing" class="mobile-link text-sm py-2 transition-colors text-white/70 hover:text-white">Pricing</a>
      <a href="#demo" id="mobile-cta" class="inline-flex items-center justify-center gap-2 px-5 py-2.5 text-sm font-medium rounded-lg mt-2 transition-all duration-300 bg-white/15 text-white border border-white/20 hover:bg-white/25">Request a Demo</a>
    </div>
  </div>
</nav>

<script>
  const nav = document.getElementById('main-nav');
  const logoDark = document.getElementById('logo-dark');
  const logoLight = document.getElementById('logo-light');
  const navLinks = document.querySelectorAll('.nav-link');
  const mobileLinks = document.querySelectorAll('.mobile-link');
  const navCta = document.getElementById('nav-cta');
  const mobileCta = document.getElementById('mobile-cta');
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');

  let scrolled = false;

  function updateNav() {
    const hero = document.querySelector('section');
    const threshold = hero ? hero.offsetHeight - 80 : 500;
    const isScrolled = window.scrollY > threshold;

    if (isScrolled === scrolled) return;
    scrolled = isScrolled;

    if (isScrolled) {
      // Light mode (over white sections)
      nav?.classList.remove('bg-white/10', 'border-white/20', 'shadow-black/5');
      nav?.classList.add('bg-white/80', 'border-gray-200', 'shadow-black/[0.03]');

      logoDark?.classList.add('hidden');
      logoLight?.classList.remove('hidden', 'absolute');

      navLinks.forEach(l => { l.className = l.className.replace('text-white/70', 'text-gray-600').replace('hover:text-white', 'hover:text-gray-900'); });
      mobileLinks.forEach(l => { l.className = l.className.replace('text-white/70', 'text-gray-600').replace('hover:text-white', 'hover:text-gray-900'); });

      btn?.classList.remove('text-white/70', 'hover:text-white');
      btn?.classList.add('text-gray-600', 'hover:text-gray-900');

      navCta?.classList.remove('bg-white/15', 'text-white', 'border-white/20', 'hover:bg-white/25');
      navCta?.classList.add('bg-primary', 'text-white', 'border-primary', 'hover:bg-primary-dark');

      mobileCta?.classList.remove('bg-white/15', 'text-white', 'border-white/20', 'hover:bg-white/25');
      mobileCta?.classList.add('bg-primary', 'text-white', 'border-primary', 'hover:bg-primary-dark');

      menu?.classList.remove('border-white/10', 'bg-white/10');
      menu?.classList.add('border-gray-200', 'bg-white/80');
    } else {
      // Dark mode (over hero)
      nav?.classList.remove('bg-white/80', 'border-gray-200', 'shadow-black/[0.03]');
      nav?.classList.add('bg-white/10', 'border-white/20', 'shadow-black/5');

      logoDark?.classList.remove('hidden');
      logoLight?.classList.add('hidden', 'absolute');

      navLinks.forEach(l => { l.className = l.className.replace('text-gray-600', 'text-white/70').replace('hover:text-gray-900', 'hover:text-white'); });
      mobileLinks.forEach(l => { l.className = l.className.replace('text-gray-600', 'text-white/70').replace('hover:text-gray-900', 'hover:text-white'); });

      btn?.classList.remove('text-gray-600', 'hover:text-gray-900');
      btn?.classList.add('text-white/70', 'hover:text-white');

      navCta?.classList.remove('bg-primary', 'border-primary', 'hover:bg-primary-dark');
      navCta?.classList.add('bg-white/15', 'text-white', 'border-white/20', 'hover:bg-white/25');

      mobileCta?.classList.remove('bg-primary', 'border-primary', 'hover:bg-primary-dark');
      mobileCta?.classList.add('bg-white/15', 'text-white', 'border-white/20', 'hover:bg-white/25');

      menu?.classList.remove('border-gray-200', 'bg-white/80');
      menu?.classList.add('border-white/10', 'bg-white/10');
    }
  }

  window.addEventListener('scroll', updateNav, { passive: true });
  updateNav();

  // Mobile menu toggle
  btn?.addEventListener('click', () => {
    if (menu?.classList.contains('max-h-0')) {
      menu.classList.remove('max-h-0', 'opacity-0');
      menu.classList.add('max-h-60', 'opacity-100');
    } else {
      menu?.classList.remove('max-h-60', 'opacity-100');
      menu?.classList.add('max-h-0', 'opacity-0');
    }
  });

  menu?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => {
      menu?.classList.remove('max-h-60', 'opacity-100');
      menu?.classList.add('max-h-0', 'opacity-0');
    });
  });
</script>
