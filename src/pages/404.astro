---
import Layout from '../layouts/Layout.astro';
---

<Layout title="404 — Page Not Found | Hostbase" description="The page you're looking for doesn't exist.">
  <div class="min-h-screen flex flex-col items-center justify-center bg-surface-dark text-white px-6">
    <a href="/">
      <img
        src="/brand/hostbase-brand-assets/logos/full-logo/hostbase-logo-full-color-dark.svg"
        alt="Hostbase"
        class="h-10 mb-12"
      />
    </a>
    <h1 class="text-6xl font-bold tracking-tight font-display mb-4">
      <span class="text-primary">404</span>
    </h1>
    <p class="text-xl text-slate-300 mb-8">This page doesn't exist.</p>
    <a
      href="/"
      class="inline-flex items-center gap-2 px-6 py-3 bg-primary text-white font-medium rounded-xl hover:bg-primary-light transition-all"
    >
      Back to Home
      <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
        <path d="M6 3l5 5-5 5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </a>
  </div>
</Layout>
