---
const features = [
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg>`,
    title: 'Channel Management',
    description: 'Connect to Booking.com, Airbnb, Expedia, and VRBO in minutes. Availability, rates, and restrictions sync automatically across every channel.',
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M3 10h18"/><path d="M16 2v4M8 2v4"/></svg>`,
    title: 'Smart Calendar',
    description: 'Drag-and-drop calendar with real-time availability. Manage bookings, room shuffles, and late checkouts from one unified view.',
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>`,
    title: 'Guest Messaging',
    description: 'Unified inbox for all OTA messages. Reply to Booking.com and Airbnb guests from one place with email notifications for new messages.',
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20V10"/><path d="M18 20V4"/><path d="M6 20v-4"/></svg>`,
    title: 'Revenue Analytics',
    description: 'Track occupancy, revenue, and OTA commissions in real time. Weekday, weekend, and off-peak rate management built in.',
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>`,
    title: 'Automated Sync',
    description: 'Full sync on demand, daily sync at 3 AM, and real-time queue processing. Rates and availability always match across every channel.',
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>`,
    title: 'White-Label Ready',
    description: 'Your logo, your colors, your subdomain. Give your guests and team a branded experience — no "powered by" in sight.',
  },
];
---

<section id="features" class="py-20 md:py-28 bg-white">
  <div class="max-w-6xl mx-auto px-6">
    <!-- Section header -->
    <div class="text-center max-w-2xl mx-auto mb-16">
      <p class="text-sm font-semibold text-primary tracking-wide uppercase mb-3">Features</p>
      <h2 class="text-3xl md:text-4xl font-bold tracking-tight text-text font-display">
        Everything you need to manage your properties
      </h2>
      <p class="mt-4 text-text-muted text-lg">
        From channel distribution to guest communications — one platform, fully branded as yours.
      </p>
    </div>

    <!-- Features list -->
    <div class="space-y-6">
      {features.map((feature, i) => (
        <article class={`group grid md:grid-cols-[auto_1fr] gap-6 items-start p-6 md:p-8 rounded-2xl border border-border bg-white hover:border-primary/30 hover:shadow-lg hover:shadow-primary/5 transition-all duration-300 animate-fade-in-up delay-${(i + 1) * 100}`}>
          <div class="w-12 h-12 rounded-xl bg-primary/10 flex items-center justify-center text-primary shrink-0 group-hover:bg-primary group-hover:text-white transition-colors duration-300">
            <Fragment set:html={feature.icon} />
          </div>
          <div>
            <h3 class="text-lg font-semibold text-text mb-1">{feature.title}</h3>
            <p class="text-text-muted leading-relaxed">{feature.description}</p>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
