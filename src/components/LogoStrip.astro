---
const otas = [
  { name: 'Booking.com', src: '/logos/booking.svg', width: 'w-28' },
  { name: 'Airbnb', src: '/logos/airbnb.svg', width: 'w-20' },
  { name: 'Expedia', src: '/logos/expedia.svg', width: 'w-24' },
  { name: 'VRBO', src: '/logos/vrbo.svg', width: 'w-20' },
  { name: 'Agoda', src: '/logos/agoda.svg', width: 'w-20' },
  { name: 'Hotels.com', src: '/logos/hotels-com.svg', width: 'w-28' },
  { name: 'TripAdvisor', src: '/logos/tripadvisor.svg', width: 'w-28' },
  { name: 'Trip.com', src: '/logos/trip-com.svg', width: 'w-24' },
  { name: 'Google Travel', src: '/logos/google-travel.svg', width: 'w-24' },
  { name: 'HomeToGo', src: '/logos/hometogo.svg', width: 'w-24' },
];
const allLogos = [...otas, ...otas];
---

<section class="relative py-10 bg-[#0a0e1a] border-t border-white/5 overflow-hidden">
  <div class="absolute inset-0 bg-gradient-to-b from-[#0a0e1a] to-surface-dark"></div>

  <p class="relative z-10 text-center text-[13px] text-slate-500 uppercase tracking-[0.2em] mb-8 font-medium">
    Integrated with the platforms you already use
  </p>

  <div class="relative z-10 marquee-mask">
    <div class="marquee-track flex items-center w-max">
      {allLogos.map((ota) => (
        <div class={`shrink-0 mx-10 md:mx-14 ${ota.width}`} title={ota.name}>
          <img
            src={ota.src}
            alt={ota.name}
            class="h-7 md:h-8 w-full object-contain"
            style="opacity: 0.5; transition: opacity 0.4s ease;"
            loading="lazy"
            onmouseover="this.style.opacity='0.8'"
            onmouseout="this.style.opacity='0.5'"
          />
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .marquee-mask {
    mask-image: linear-gradient(to right, transparent, black 8%, black 92%, transparent);
    -webkit-mask-image: linear-gradient(to right, transparent, black 8%, black 92%, transparent);
  }

  .marquee-track {
    animation: marquee-scroll 30s linear infinite;
    will-change: transform;
  }

  @keyframes marquee-scroll {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  @media (prefers-reduced-motion: reduce) {
    .marquee-track {
      animation: none;
    }
  }
</style>
