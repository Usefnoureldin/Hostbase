<footer class="border-t border-border bg-white py-12">
  <div class="max-w-6xl mx-auto px-6">
    <div class="flex flex-col md:flex-row items-center justify-between gap-6">
      <!-- Logo -->
      <div class="flex items-center">
        <img src="/brand/hostbase-brand-assets/logos/full-logo/hostbase-logo-full-color-light.svg" alt="Hostbase" class="h-7" />
      </div>

      <!-- Links -->
      <div class="flex items-center gap-6 text-sm text-text-muted">
        <a href="#features" class="hover:text-text transition-colors">Features</a>
        <a href="#pricing" class="hover:text-text transition-colors">Pricing</a>
        <a href="mailto:hello@hostbase.ai" class="hover:text-text transition-colors">Contact</a>
      </div>

      <!-- Copyright -->
      <p class="text-sm text-text-muted">
        &copy; {new Date().getFullYear()} Hostbase. All rights reserved.
      </p>
    </div>
  </div>
</footer>
