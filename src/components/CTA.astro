---
---
<section id="demo" class="py-20 md:py-28">
  <div class="max-w-6xl mx-auto px-6">
    <div class="relative rounded-3xl bg-surface-dark overflow-hidden px-8 py-16 md:px-16 md:py-20 text-center">
      <!-- Background decoration -->
      <div class="absolute top-0 left-0 w-full h-full overflow-hidden -z-0">
        <div class="absolute -top-24 -right-24 w-96 h-96 bg-primary/20 rounded-full blur-3xl"></div>
        <div class="absolute -bottom-24 -left-24 w-96 h-96 bg-primary/10 rounded-full blur-3xl"></div>
      </div>

      <div class="relative z-10">
        <h2 class="text-3xl md:text-5xl font-bold text-white tracking-tight max-w-2xl mx-auto leading-tight font-display">
          Built by operators. For operators.
        </h2>
        <p class="mt-5 text-lg text-slate-300 max-w-xl mx-auto">
          See how Hostbase runs your properties, channels, and pricing from one platform — with your brand on every screen.
        </p>
        <div class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-4">
          <a
            href="mailto:founders@hostbase.ai?subject=Hostbase Demo Request"
            class="inline-flex items-center gap-2 px-8 py-4 bg-primary text-white font-medium rounded-xl hover:bg-primary-light transition-all shadow-lg shadow-primary/30 hover:shadow-xl hover:-translate-y-0.5 text-lg"
          >
            Request a Demo
            <svg width="18" height="18" viewBox="0 0 16 16" fill="none">
              <path d="M6 3l5 5-5 5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        </div>
        <p class="mt-6 text-sm text-slate-400">
          No credit card required. Free setup for your first property.
        </p>
      </div>
    </div>
  </div>
</section>
