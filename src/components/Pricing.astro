---
const plans = [
  {
    name: 'Launch',
    price: 99,
    unit: '/ month',
    slider: {
      min: 1,
      max: 2,
      default: 1,
      pricePerProperty: { 1: 99, 2: 74.5 },
    },
    description: 'Built for independent operators. Go from zero to live on Booking.com and Airbnb in minutes.',
    features: [
      'Unlimited listings',
      'Channel manager for Booking.com & Airbnb',
      { text: 'Intelligent room auto-shuffle system', tooltip: 'Guests get reassigned to available rooms automatically. No manual reshuffling.' },
      { text: 'Custom rates per day of week', tooltip: 'Charge more on weekends, less on weekdays. You pick the rate for each day.' },
      'Unified guest messaging inbox',
      'Revenue analytics dashboard',
      'Email notifications',
    ],
    cta: 'Request a Demo',
    highlighted: false,
  },
  {
    name: 'Pro',
    price: 399,
    unit: '/ month',
    slider: {
      min: 1,
      max: 5,
      default: 1,
      pricePerProperty: { 1: 399, 2: 349, 3: 329, 4: 299, 5: 249 },
    },
    description: 'For operators with up to 5 properties. Manage and grow your portfolio across every channel. Rates sync automatically, AI optimizes the rest. You handle the guests.',
    introLine: 'Everything in Launch, plus...',
    features: [
      'Channel manager (10+ OTAs)',
      'Dynamic pricing algorithm',
      { text: 'Auto-markup rates per OTA channel', tooltip: 'Set one rate, sell at different prices per channel' },
      'White-label subdomain',
      'Priority support',
    ],
    cta: 'Request a Demo',
    highlighted: true,
  },
  {
    name: 'Enterprise',
    price: null,
    unit: '',
    description: 'For operators managing 5+ properties. Dynamic pricing, AI-powered operations, landlord reporting, and full white-label branding on your own domain. Everything tailored to your portfolio.',
    introLine: 'Everything in Pro, plus...',
    features: [
      { text: 'Promotional campaigns across all channels', tooltip: 'Design a promotion once. Discounts flow automatically to Booking.com, Airbnb, Expedia, and Vrbo at the right rate, on the right nights.' },
      { text: 'Claude + ChatGPT MCP', tooltip: 'Query your entire operation in plain English. Revenue, occupancy, guest data, all through AI.' },
      'Custom Landlord View',
      'Dedicated onboarding',
      'Dedicated website. Your brand, your domain',
    ],
    cta: 'Request a Demo',
    highlighted: false,
  },
];
---

<section id="pricing" class="py-20 md:py-28 bg-surface-alt">
  <div class="max-w-6xl mx-auto px-6">
    <!-- Section header -->
    <div class="text-center max-w-2xl mx-auto mb-16">
      <p class="text-sm font-semibold text-primary tracking-wide uppercase mb-3">Pricing</p>
      <h2 class="text-3xl md:text-4xl font-bold tracking-tight text-text font-display">
        Pricing that rewards scale.
      </h2>
      <p class="mt-4 text-text-muted text-lg">
        One flat rate per property. Unlimited listings, unlimited rooms. No hidden fees. Cancel anytime.
      </p>
    </div>

    <!-- Pricing cards -->
    <div class="grid md:grid-cols-3 gap-6 max-w-5xl mx-auto">
      {plans.map((plan) => {
        const planSlug = plan.name.toLowerCase().replace(/\s+/g, '-');
        const fmt = (n: number) => Number.isInteger(n) ? n.toLocaleString() : n.toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 });
        return (
        <div data-pricing-card class={`relative rounded-2xl p-8 flex flex-col transition-all duration-300 ${
          plan.highlighted
            ? 'bg-white border-2 border-primary shadow-xl shadow-primary/10 scale-[1.02]'
            : 'bg-white border border-border hover:border-primary/30 hover:shadow-lg'
        }`}>
          {plan.highlighted && (
            <div class="absolute -top-3.5 left-1/2 -translate-x-1/2">
              <span class="px-4 py-1 bg-primary text-white text-xs font-semibold rounded-full">Most Popular</span>
            </div>
          )}

          <div class="mb-6">
            <h3 class="text-2xl md:text-3xl font-bold tracking-tight text-text">{plan.name}</h3>
          </div>

          <div class="mb-6">
            <div class="flex items-baseline gap-1">
              {plan.price !== null ? (
                <>
                  <span
                    class="text-4xl font-bold text-text"
                    data-price-display={plan.slider ? '' : undefined}
                    data-price-tiers={plan.slider ? JSON.stringify(plan.slider.pricePerProperty) : undefined}
                  >${plan.slider ? fmt(plan.slider.default * plan.slider.pricePerProperty[plan.slider.default]) : plan.price}</span>
                  <span class="text-text-muted text-sm">{plan.unit}</span>
                </>
              ) : (
                <span class="text-4xl font-bold text-text">Custom</span>
              )}
            </div>
            {plan.slider && (
              <>
                <p class="text-sm text-text-muted mt-1">
                  <span data-per-property>${fmt(plan.slider.pricePerProperty[plan.slider.default])}</span> / property
                </p>
                <div class="mt-4">
                  <div class="flex items-center justify-between mb-2">
                    <label class="text-sm text-text-muted">Properties</label>
                    <span class="text-sm font-semibold text-text">
                      <span data-properties-count>{plan.slider.default}</span>
                      <span data-properties-label>{plan.slider.default === 1 ? 'property' : 'properties'}</span>
                    </span>
                  </div>
                  <div
                    data-stepped-slider
                    data-min={plan.slider.min}
                    data-max={plan.slider.max}
                    data-value={plan.slider.default}
                    class="relative select-none"
                    role="slider"
                    tabindex="0"
                    aria-label="Number of properties"
                    aria-valuemin={plan.slider.min}
                    aria-valuemax={plan.slider.max}
                    aria-valuenow={plan.slider.default}
                  >
                    <div class="slider-track relative h-1 bg-border rounded-full cursor-pointer">
                      <div class="slider-fill absolute left-0 top-0 h-full bg-primary rounded-full pointer-events-none"></div>
                      <div class="slider-ticks absolute inset-0 flex justify-between items-center pointer-events-none">
                        {Array.from({ length: plan.slider.max - plan.slider.min + 1 }, (_, i) => (
                          <div class="slider-tick w-2.5 h-2.5 rounded-full bg-border border-2 border-white transition-colors z-10" data-tick-index={i}></div>
                        ))}
                      </div>
                      <div class="slider-thumb absolute top-1/2 -translate-y-1/2 w-[22px] h-[22px] rounded-full bg-primary border-[3px] border-white shadow-md cursor-grab active:cursor-grabbing transition-[left] duration-100 ease-out pointer-events-none z-20" style="left: 0;"></div>
                    </div>
                    <div class="slider-labels flex justify-between mt-3 text-xs text-text-muted pointer-events-none">
                      {Array.from({ length: plan.slider.max - plan.slider.min + 1 }, (_, i) => (
                        <span class="slider-label text-center transition-opacity duration-150" data-label-index={i}>{plan.slider!.min + i}</span>
                      ))}
                    </div>
                  </div>
                </div>
              </>
            )}
            <p class="text-sm text-text-muted mt-3">{plan.description}</p>
          </div>

          <div class="flex-1 mb-8">
            {plan.introLine && (
              <p class="text-base font-bold italic text-text-muted mb-4">{plan.introLine}</p>
            )}
            <ul class="space-y-3">
            {plan.features.map((feature) => (
              <li class="flex items-start gap-3 text-sm text-text">
                <svg class="w-5 h-5 text-primary shrink-0 mt-0.5" viewBox="0 0 20 20" fill="currentColor">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                </svg>
                {typeof feature === 'string' ? feature : (
                  <span class="inline-flex items-center gap-1.5">
                    {feature.text}
                    <button type="button" class="tooltip-trigger relative inline-flex items-center" aria-label="More info">
                      <svg class="w-4 h-4 text-text-muted cursor-pointer hover:text-primary transition-colors" viewBox="0 0 20 20" fill="currentColor">
                        <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd"/>
                      </svg>
                      <span class="tooltip-text absolute bottom-full right-0 mb-2 px-3 py-2 text-xs text-white bg-gray-900 rounded-lg opacity-0 pointer-events-none transition-opacity duration-200 z-50 shadow-lg max-w-[250px] whitespace-normal text-left">{feature.tooltip}</span>
                    </button>
                  </span>
                )}
              </li>
            ))}
            </ul>
          </div>

          <button
            type="button"
            data-demo-trigger
            data-plan={plan.name}
            class={`inline-flex items-center justify-center py-3 px-6 rounded-xl font-medium text-sm transition-all cursor-pointer ${
              plan.highlighted
                ? 'bg-primary text-white hover:bg-primary-dark shadow-lg shadow-primary/25'
                : 'bg-surface-alt text-text hover:bg-primary/10 hover:text-primary border border-border'
            }`}
          >
            {plan.cta}
          </button>
        </div>
        );
      })}
    </div>
  </div>
</section>

<!-- Demo Request Modal -->
<div id="demo-modal" class="fixed inset-0 z-50 hidden items-center justify-center">
  <div id="demo-backdrop" class="absolute inset-0 bg-black/50 backdrop-blur-sm"></div>
  <div class="relative bg-white rounded-2xl shadow-2xl w-full max-w-md mx-4 p-8 animate-fade-in-up">
    <button type="button" id="demo-close" class="absolute top-4 right-4 text-text-muted hover:text-text transition-colors cursor-pointer" aria-label="Close">
      <svg class="w-5 h-5" viewBox="0 0 20 20" fill="currentColor">
        <path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd"/>
      </svg>
    </button>

    <div id="demo-form-view">
      <h3 class="text-2xl font-bold text-text font-display mb-1">Request a Demo</h3>
      <p class="text-sm text-text-muted mb-6">We'll get back to you within 24 hours.</p>

      <form id="demo-form" class="space-y-4">
        <input type="hidden" id="demo-plan" name="plan" />

        <div class="grid grid-cols-2 gap-4">
          <div>
            <label for="demo-first-name" class="block text-sm font-medium text-text mb-1.5">First Name</label>
            <input type="text" id="demo-first-name" name="firstName" required
              class="w-full px-3.5 py-2.5 rounded-xl border border-border text-sm text-text placeholder:text-text-muted/50 focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary transition-colors" placeholder="John" />
          </div>
          <div>
            <label for="demo-last-name" class="block text-sm font-medium text-text mb-1.5">Last Name</label>
            <input type="text" id="demo-last-name" name="lastName" required
              class="w-full px-3.5 py-2.5 rounded-xl border border-border text-sm text-text placeholder:text-text-muted/50 focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary transition-colors" placeholder="Doe" />
          </div>
        </div>

        <div>
          <label for="demo-email" class="block text-sm font-medium text-text mb-1.5">Email</label>
          <input type="email" id="demo-email" name="email" required
            class="w-full px-3.5 py-2.5 rounded-xl border border-border text-sm text-text placeholder:text-text-muted/50 focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary transition-colors" placeholder="john@company.com" />
        </div>

        <div>
          <label for="demo-phone" class="block text-sm font-medium text-text mb-1.5">Phone Number <span class="text-text-muted font-normal">(optional)</span></label>
          <input type="tel" id="demo-phone" name="phone"
            class="w-full px-3.5 py-2.5 rounded-xl border border-border text-sm text-text placeholder:text-text-muted/50 focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary transition-colors" placeholder="+1 (555) 000-0000" />
        </div>

        <div>
          <label for="demo-properties" class="block text-sm font-medium text-text mb-1.5">Number of Properties</label>
          <select id="demo-properties" name="properties" required
            class="w-full px-3.5 py-2.5 rounded-xl border border-border text-sm text-text focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary transition-colors bg-white">
            <option value="">Select...</option>
            <option value="1">1</option>
            <option value="2-5">2–5</option>
            <option value="6-10">6–10</option>
            <option value="11-20">11–20</option>
            <option value="20+">20+</option>
          </select>
        </div>

        <div>
          <label for="demo-plan-display" class="block text-sm font-medium text-text mb-1.5">Plan</label>
          <input type="text" id="demo-plan-display" readonly
            class="w-full px-3.5 py-2.5 rounded-xl border border-border text-sm text-text-muted bg-surface-alt cursor-not-allowed" />
        </div>

        <button type="submit" class="w-full py-3 px-6 rounded-xl bg-primary text-white font-medium text-sm hover:bg-primary-dark shadow-lg shadow-primary/25 transition-all cursor-pointer mt-2">
          Submit Request
        </button>
      </form>
    </div>

    <div id="demo-success-view" class="hidden text-center py-6">
      <div class="w-14 h-14 rounded-full bg-primary/10 flex items-center justify-center mx-auto mb-4">
        <svg class="w-7 h-7 text-primary" viewBox="0 0 20 20" fill="currentColor">
          <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
        </svg>
      </div>
      <h3 class="text-2xl font-bold text-text font-display mb-2">We'll be in touch!</h3>
      <p class="text-sm text-text-muted">Our team will reach out within 24 hours to schedule your demo.</p>
    </div>
  </div>
</div>

<style>
  .tooltip-trigger.active .tooltip-text,
  .tooltip-trigger:hover .tooltip-text {
    opacity: 1;
    pointer-events: auto;
  }

  [data-stepped-slider] .slider-tick.active {
    background: var(--color-primary);
  }
  [data-stepped-slider]:focus-visible .slider-thumb {
    box-shadow: 0 1px 3px rgba(0,0,0,.2), 0 0 0 3px color-mix(in srgb, var(--color-primary) 30%, transparent);
  }
</style>

<script>
  const fmt = (n: number) => Number.isInteger(n)
    ? n.toLocaleString()
    : n.toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 });

  document.querySelectorAll<HTMLElement>('[data-pricing-card]').forEach((card) => {
    const sliderEl = card.querySelector<HTMLElement>('[data-stepped-slider]');
    const priceEl = card.querySelector<HTMLElement>('[data-price-display]');
    const perPropEl = card.querySelector<HTMLElement>('[data-per-property]');
    const countEl = card.querySelector<HTMLElement>('[data-properties-count]');
    const labelEl = card.querySelector<HTMLElement>('[data-properties-label]');
    if (!sliderEl || !priceEl || !perPropEl || !countEl || !labelEl) return;

    const tiers: Record<string, number> = JSON.parse(priceEl.dataset.priceTiers || '{}');
    const min = Number(sliderEl.dataset.min);
    const max = Number(sliderEl.dataset.max);
    const steps = max - min;
    let current = Number(sliderEl.dataset.value);

    const track = sliderEl.querySelector<HTMLElement>('.slider-track')!;
    const fill = sliderEl.querySelector<HTMLElement>('.slider-fill')!;
    const thumb = sliderEl.querySelector<HTMLElement>('.slider-thumb')!;
    const ticks = sliderEl.querySelectorAll<HTMLElement>('.slider-tick');
    const labels = sliderEl.querySelectorAll<HTMLElement>('.slider-label');

    const setValue = (val: number) => {
      current = Math.max(min, Math.min(max, Math.round(val)));
      const pct = steps === 0 ? 0 : ((current - min) / steps) * 100;
      thumb.style.left = `calc(${pct}% - 11px)`;
      fill.style.width = `${pct}%`;
      ticks.forEach((tick, i) => {
        tick.classList.toggle('active', i <= current - min);
      });
      labels.forEach((label, i) => {
        label.style.opacity = i === current - min ? '0' : '1';
      });
      sliderEl.setAttribute('aria-valuenow', String(current));

      const perProp = tiers[String(current)] ?? 0;
      priceEl.textContent = '$' + fmt(current * perProp);
      perPropEl.textContent = '$' + fmt(perProp);
      countEl.textContent = String(current);
      labelEl.textContent = current === 1 ? 'property' : 'properties';
    };

    const getValueFromX = (clientX: number) => {
      const rect = track.getBoundingClientRect();
      const ratio = Math.max(0, Math.min(1, (clientX - rect.left) / rect.width));
      return min + ratio * steps;
    };

    track.addEventListener('pointerdown', (e) => {
      e.preventDefault();
      setValue(getValueFromX(e.clientX));
      const onMove = (ev: PointerEvent) => setValue(getValueFromX(ev.clientX));
      const onUp = () => {
        document.removeEventListener('pointermove', onMove);
        document.removeEventListener('pointerup', onUp);
      };
      document.addEventListener('pointermove', onMove);
      document.addEventListener('pointerup', onUp);
    });

    sliderEl.addEventListener('keydown', (e) => {
      if (e.key === 'ArrowRight' || e.key === 'ArrowUp') { e.preventDefault(); setValue(current + 1); }
      if (e.key === 'ArrowLeft' || e.key === 'ArrowDown') { e.preventDefault(); setValue(current - 1); }
    });

    setValue(current);
  });

  document.querySelectorAll<HTMLElement>('.tooltip-trigger').forEach((btn) => {
    btn.addEventListener('click', (e) => {
      e.stopPropagation();
      const wasActive = btn.classList.contains('active');
      document.querySelectorAll('.tooltip-trigger.active').forEach((b) => b.classList.remove('active'));
      if (!wasActive) btn.classList.add('active');
    });
  });

  document.addEventListener('click', () => {
    document.querySelectorAll('.tooltip-trigger.active').forEach((b) => b.classList.remove('active'));
  });

  // Demo modal
  const modal = document.getElementById('demo-modal')!;
  const backdrop = document.getElementById('demo-backdrop')!;
  const closeBtn = document.getElementById('demo-close')!;
  const form = document.getElementById('demo-form') as HTMLFormElement;
  const planInput = document.getElementById('demo-plan') as HTMLInputElement;
  const planDisplay = document.getElementById('demo-plan-display') as HTMLInputElement;
  const formView = document.getElementById('demo-form-view')!;
  const successView = document.getElementById('demo-success-view')!;

  const openModal = (plan: string) => {
    planInput.value = plan;
    planDisplay.value = plan;
    form.reset();
    planInput.value = plan;
    planDisplay.value = plan;
    formView.classList.remove('hidden');
    successView.classList.add('hidden');
    modal.classList.remove('hidden');
    modal.classList.add('flex');
    document.body.style.overflow = 'hidden';
  };

  const closeModal = () => {
    modal.classList.add('hidden');
    modal.classList.remove('flex');
    document.body.style.overflow = '';
  };

  document.querySelectorAll<HTMLButtonElement>('[data-demo-trigger]').forEach((btn) => {
    btn.addEventListener('click', () => openModal(btn.dataset.plan || ''));
  });

  closeBtn.addEventListener('click', closeModal);
  backdrop.addEventListener('click', closeModal);
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && !modal.classList.contains('hidden')) closeModal();
  });

  form.addEventListener('submit', (e) => {
    e.preventDefault();
    const data = new FormData(form);
    const firstName = data.get('firstName');
    const lastName = data.get('lastName');
    const email = data.get('email');
    const phone = data.get('phone');
    const properties = data.get('properties');
    const plan = data.get('plan');

    const subject = encodeURIComponent(`Demo Request — ${plan} Plan`);
    const body = encodeURIComponent(
      `Name: ${firstName} ${lastName}\nEmail: ${email}\nPhone: ${phone || 'N/A'}\nProperties: ${properties}\nPlan: ${plan}`
    );
    window.location.href = `mailto:founders@hostbase.ai?subject=${subject}&body=${body}`;

    formView.classList.add('hidden');
    successView.classList.remove('hidden');
  });
</script>
