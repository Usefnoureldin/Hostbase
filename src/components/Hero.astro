---
---
<section class="relative pt-32 pb-20 md:pt-40 md:pb-28 overflow-hidden">
  <!-- Dark background -->
  <div class="absolute inset-0 bg-[#0a0e1a] -z-10"></div>

  <!-- Aurora glow blobs -->
  <div class="absolute top-[-200px] left-1/2 -translate-x-1/2 w-[1000px] h-[600px] bg-gradient-to-br from-teal-500/20 via-emerald-400/10 to-cyan-500/15 rounded-full blur-[120px] -z-[5]"></div>
  <div class="absolute top-[100px] left-[10%] w-[400px] h-[400px] bg-primary/10 rounded-full blur-[100px] -z-[5]"></div>
  <div class="absolute top-[50px] right-[10%] w-[350px] h-[350px] bg-cyan-400/8 rounded-full blur-[100px] -z-[5]"></div>

  <!-- Stars -->
  <div class="absolute inset-0 -z-[3]" id="stars-container">
    <!-- Static stars rendered via CSS -->
    <div class="star" style="top:8%;left:12%;--size:2px;--delay:0s;--duration:3s;"></div>
    <div class="star" style="top:15%;left:78%;--size:1.5px;--delay:0.5s;--duration:4s;"></div>
    <div class="star" style="top:22%;left:45%;--size:1px;--delay:1s;--duration:3.5s;"></div>
    <div class="star" style="top:5%;left:65%;--size:2.5px;--delay:0.3s;--duration:5s;"></div>
    <div class="star" style="top:30%;left:20%;--size:1px;--delay:1.5s;--duration:4s;"></div>
    <div class="star" style="top:12%;left:90%;--size:2px;--delay:0.8s;--duration:3s;"></div>
    <div class="star" style="top:35%;left:55%;--size:1.5px;--delay:2s;--duration:4.5s;"></div>
    <div class="star" style="top:18%;left:35%;--size:1px;--delay:0.2s;--duration:3s;"></div>
    <div class="star" style="top:8%;left:50%;--size:2px;--delay:1.2s;--duration:5s;"></div>
    <div class="star" style="top:25%;left:8%;--size:1.5px;--delay:0.7s;--duration:3.5s;"></div>
    <div class="star" style="top:3%;left:30%;--size:1px;--delay:2.5s;--duration:4s;"></div>
    <div class="star" style="top:28%;left:72%;--size:2px;--delay:1.8s;--duration:3s;"></div>
    <div class="star" style="top:10%;left:85%;--size:1px;--delay:0.4s;--duration:5s;"></div>
    <div class="star" style="top:38%;left:40%;--size:2.5px;--delay:3s;--duration:4s;"></div>
    <div class="star" style="top:20%;left:58%;--size:1px;--delay:1.6s;--duration:3.5s;"></div>
    <div class="star" style="top:6%;left:22%;--size:1.5px;--delay:0.9s;--duration:4.5s;"></div>
    <div class="star" style="top:32%;left:88%;--size:2px;--delay:2.2s;--duration:3s;"></div>
    <div class="star" style="top:14%;left:5%;--size:1px;--delay:1.1s;--duration:5s;"></div>
    <div class="star" style="top:40%;left:15%;--size:1.5px;--delay:0.6s;--duration:4s;"></div>
    <div class="star" style="top:2%;left:42%;--size:2px;--delay:2.8s;--duration:3.5s;"></div>
    <div class="star" style="top:36%;left:68%;--size:1px;--delay:1.4s;--duration:4.5s;"></div>
    <div class="star" style="top:16%;left:52%;--size:2.5px;--delay:0.1s;--duration:3s;"></div>
    <div class="star" style="top:42%;left:32%;--size:1px;--delay:3.2s;--duration:5s;"></div>
    <div class="star" style="top:9%;left:75%;--size:1.5px;--delay:1.9s;--duration:4s;"></div>
    <div class="star" style="top:26%;left:95%;--size:2px;--delay:0.5s;--duration:3.5s;"></div>

    <!-- Sparkle stars (larger, with glow) -->
    <div class="sparkle" style="top:10%;left:25%;--delay:0s;--duration:4s;"></div>
    <div class="sparkle" style="top:20%;left:70%;--delay:1.5s;--duration:5s;"></div>
    <div class="sparkle" style="top:35%;left:45%;--delay:3s;--duration:4.5s;"></div>
    <div class="sparkle" style="top:5%;left:55%;--delay:2s;--duration:3.5s;"></div>
    <div class="sparkle" style="top:28%;left:15%;--delay:0.8s;--duration:5s;"></div>
    <div class="sparkle" style="top:15%;left:85%;--delay:2.5s;--duration:4s;"></div>
  </div>

  <div class="max-w-6xl mx-auto px-6 text-center relative z-10">
    <!-- Badge -->
    <div class="animate-fade-in-up inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-white/10 backdrop-blur-sm text-teal-300 text-sm font-medium mb-8 border border-white/10">
      <span class="w-1.5 h-1.5 rounded-full bg-teal-400 animate-pulse"></span>
      AI-Native All-in-1 PMS
    </div>

    <!-- Headline -->
    <h1 class="animate-fade-in-up delay-100 text-4xl md:text-6xl lg:text-7xl font-bold tracking-tight text-white leading-[1.1] max-w-4xl mx-auto hero-headline">
      Future of Short-Term Rentals is
      <span class="hero-gradient-text">Run by Hostbase</span>
    </h1>

    <!-- Subheadline -->
    <p class="animate-fade-in-up delay-200 mt-6 text-lg md:text-xl text-slate-400 max-w-2xl mx-auto leading-relaxed">
      One platform replaces your PMS, channel manager, pricing tool, and guest CRM.
      AI runs the backend. Your brand runs the frontend.
    </p>

    <!-- CTAs -->
    <div class="animate-fade-in-up delay-300 mt-10 flex flex-col sm:flex-row items-center justify-center gap-4">
      <a
        href="mailto:founders@hostbase.ai?subject=Hostbase Demo Request"
        class="inline-flex items-center gap-2 px-7 py-3.5 bg-primary text-white font-medium rounded-xl hover:bg-primary-light transition-all shadow-lg shadow-primary/30 hover:shadow-xl hover:shadow-primary/40 hover:-translate-y-0.5"
      >
        Request a Demo
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
          <path d="M6 3l5 5-5 5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
      <a
        href="#features"
        class="inline-flex items-center gap-2 px-7 py-3.5 bg-white/5 text-white font-medium rounded-xl border border-white/15 hover:bg-white/10 hover:border-white/25 transition-all backdrop-blur-sm"
      >
        See how it works
      </a>
    </div>

    <!-- Hero visual: Interactive tabbed dashboard -->
    <div class="animate-fade-in-up delay-500 mt-16 md:mt-20 max-w-4xl mx-auto">
      <!-- Tab switcher -->
      <div class="flex justify-center mb-4 gap-2 hero-tabs">
        <button class="hero-tab-btn active px-4 py-2 rounded-lg text-[11px] font-medium transition-all cursor-pointer" data-panel="1">
          <span class="flex items-center gap-1.5">
            <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/></svg>
            Dynamic Pricing
          </span>
        </button>
        <button class="hero-tab-btn px-4 py-2 rounded-lg text-[11px] font-medium transition-all cursor-pointer" data-panel="2">
          <span class="flex items-center gap-1.5">
            <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z"/></svg>
            AI Assistant
          </span>
        </button>
        <button class="hero-tab-btn px-4 py-2 rounded-lg text-[11px] font-medium transition-all cursor-pointer" data-panel="3">
          <span class="flex items-center gap-1.5">
            <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>
            Landlord View
          </span>
        </button>
      </div>

      <!-- Panel 1: Dynamic Pricing (visible by default) -->
      <div class="hero-panel hero-panel-1 active-panel" data-id="1">
        <div class="rounded-2xl border border-white/10 bg-[#0d1525]/90 backdrop-blur-md shadow-2xl shadow-black/30 overflow-hidden">
          <div class="flex items-center gap-2 px-5 py-3 bg-white/5 border-b border-white/10">
            <div class="flex gap-1.5">
              <div class="w-2.5 h-2.5 rounded-full bg-red-400/60"></div>
              <div class="w-2.5 h-2.5 rounded-full bg-yellow-400/60"></div>
              <div class="w-2.5 h-2.5 rounded-full bg-green-400/60"></div>
            </div>
            <div class="flex-1 flex justify-center">
              <div class="px-3 py-0.5 rounded-md bg-teal-500/10 border border-teal-500/20 text-[10px] text-teal-400 font-medium">Dynamic Pricing Engine</div>
            </div>
          </div>
          <div class="p-6">
            <div class="mb-5">
              <div class="flex justify-between items-center mb-3">
                <p class="text-xs text-slate-400 font-medium">Demand Forecast — Next 7 Days</p>
                <p class="text-[9px] text-teal-400">AI Optimized</p>
              </div>
              <div class="rounded-lg bg-white/5 border border-white/10 p-4">
                <div class="flex items-end justify-between gap-2" style="height:80px;">
                  <div class="flex flex-col items-center gap-1 flex-1">
                    <div class="w-full bg-teal-500/15 border border-teal-500/30 rounded-sm hero-bar" style="height:25px;"></div>
                    <span class="text-[8px] text-slate-500">Mon</span>
                  </div>
                  <div class="flex flex-col items-center gap-1 flex-1">
                    <div class="w-full bg-teal-500/20 border border-teal-500/30 rounded-sm hero-bar" style="height:40px;"></div>
                    <span class="text-[8px] text-slate-500">Tue</span>
                  </div>
                  <div class="flex flex-col items-center gap-1 flex-1">
                    <div class="w-full bg-teal-500/20 border border-teal-500/30 rounded-sm hero-bar" style="height:35px;"></div>
                    <span class="text-[8px] text-slate-500">Wed</span>
                  </div>
                  <div class="flex flex-col items-center gap-1 flex-1">
                    <div class="w-full bg-teal-500/25 border border-teal-500/30 rounded-sm hero-bar" style="height:50px;"></div>
                    <span class="text-[8px] text-slate-500">Thu</span>
                  </div>
                  <div class="flex flex-col items-center gap-1 flex-1">
                    <div class="w-full bg-teal-500/40 border border-teal-500/50 rounded-sm hero-bar" style="height:70px;"></div>
                    <span class="text-[8px] text-slate-500">Fri</span>
                  </div>
                  <div class="flex flex-col items-center gap-1 flex-1">
                    <div class="w-full bg-teal-500/50 border border-teal-500/60 rounded-sm hero-bar" style="height:75px;"></div>
                    <span class="text-[8px] text-slate-500">Sat</span>
                  </div>
                  <div class="flex flex-col items-center gap-1 flex-1">
                    <div class="w-full bg-teal-500/30 border border-teal-500/40 rounded-sm hero-bar" style="height:60px;"></div>
                    <span class="text-[8px] text-slate-500">Sun</span>
                  </div>
                </div>
              </div>
            </div>
            <div class="grid grid-cols-2 gap-4">
              <div>
                <p class="text-xs text-slate-500 mb-2">AI Rate Adjustments</p>
                <div class="space-y-1.5">
                  <div class="flex justify-between items-center rounded-lg bg-white/5 border border-white/10 px-3 py-2">
                    <span class="text-[10px] text-slate-300">Mon–Wed</span>
                    <div class="flex items-center gap-1">
                      <span class="text-[10px] text-slate-500 line-through">$120</span>
                      <span class="text-[10px] font-bold text-amber-400">$99</span>
                      <span class="text-[8px] text-red-400">↓</span>
                    </div>
                  </div>
                  <div class="flex justify-between items-center rounded-lg bg-white/5 border border-white/10 px-3 py-2">
                    <span class="text-[10px] text-slate-300">Thu</span>
                    <div class="flex items-center gap-1">
                      <span class="text-[10px] text-slate-500 line-through">$120</span>
                      <span class="text-[10px] font-bold text-teal-400">$145</span>
                      <span class="text-[8px] text-emerald-400">↑</span>
                    </div>
                  </div>
                  <div class="flex justify-between items-center rounded-lg bg-teal-500/10 border border-teal-500/20 px-3 py-2">
                    <span class="text-[10px] text-white font-medium">Fri–Sat</span>
                    <div class="flex items-center gap-1">
                      <span class="text-[10px] text-slate-500 line-through">$120</span>
                      <span class="text-[10px] font-bold text-emerald-400">$195</span>
                      <span class="text-[8px] text-emerald-400">↑↑</span>
                    </div>
                  </div>
                  <div class="flex justify-between items-center rounded-lg bg-white/5 border border-white/10 px-3 py-2">
                    <span class="text-[10px] text-slate-300">Sun</span>
                    <div class="flex items-center gap-1">
                      <span class="text-[10px] text-slate-500 line-through">$120</span>
                      <span class="text-[10px] font-bold text-teal-400">$155</span>
                      <span class="text-[8px] text-emerald-400">↑</span>
                    </div>
                  </div>
                </div>
              </div>
              <div>
                <p class="text-xs text-slate-500 mb-2">Impact Projection</p>
                <div class="rounded-lg bg-white/5 border border-white/10 p-3 space-y-3">
                  <div>
                    <p class="text-[9px] text-slate-500 mb-1">Weekly Revenue</p>
                    <div class="flex items-baseline gap-2">
                      <span class="text-xl font-bold text-white">$1,084</span>
                      <span class="text-[10px] text-emerald-400">+29%</span>
                    </div>
                  </div>
                  <div>
                    <p class="text-[9px] text-slate-500 mb-1">Occupancy Target</p>
                    <div class="flex items-center gap-2">
                      <div class="flex-1 h-1.5 rounded-full bg-white/10">
                        <div class="h-full rounded-full bg-gradient-to-r from-teal-500 to-emerald-400 hero-occupancy-bar"></div>
                      </div>
                      <span class="text-[10px] text-white font-medium">92%</span>
                    </div>
                  </div>
                  <div>
                    <p class="text-[9px] text-slate-500 mb-1">Strategy</p>
                    <p class="text-[10px] text-slate-300">Lower midweek to drive volume, maximize weekend premium</p>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Panel 2: AI Assistant -->
      <div class="hero-panel hero-panel-2" data-id="2" style="display:none;">
        <div class="rounded-2xl border border-white/10 bg-[#0d1525]/90 backdrop-blur-md shadow-2xl shadow-black/30 overflow-hidden">
          <div class="flex items-center gap-2 px-5 py-3 bg-white/5 border-b border-white/10">
            <div class="flex gap-1.5">
              <div class="w-2.5 h-2.5 rounded-full bg-red-400/60"></div>
              <div class="w-2.5 h-2.5 rounded-full bg-yellow-400/60"></div>
              <div class="w-2.5 h-2.5 rounded-full bg-green-400/60"></div>
            </div>
            <div class="flex-1 flex justify-center">
              <div class="px-3 py-0.5 rounded-md bg-violet-500/10 border border-violet-500/20 text-[10px] text-violet-400 font-medium">Claude + ChatGPT MCP</div>
            </div>
          </div>
          <div class="p-5 space-y-3" style="min-height:340px;">
            <div class="flex justify-end">
              <div class="rounded-xl rounded-br-sm bg-teal-600/30 border border-teal-500/20 px-3 py-2 max-w-[75%]">
                <p class="text-[11px] text-white leading-relaxed">Optimize pricing for next week. Occupancy is low.</p>
              </div>
            </div>
            <div class="flex justify-start">
              <div class="rounded-xl rounded-bl-sm bg-white/5 border border-white/10 px-3 py-2 max-w-[75%]">
                <p class="text-[11px] text-slate-300 leading-relaxed">Analyzing demand patterns for Apr 28 – May 4...</p>
                <div class="mt-2 flex items-center gap-2">
                  <div class="h-0.5 flex-1 rounded-full bg-teal-400"></div>
                  <span class="text-[9px] text-teal-400">Done</span>
                </div>
              </div>
            </div>
            <div class="flex justify-start">
              <div class="rounded-xl rounded-bl-sm bg-white/5 border border-white/10 px-3 py-2.5 max-w-[80%]">
                <p class="text-[11px] text-slate-300 leading-relaxed mb-2">Here's what I've done:</p>
                <div class="space-y-1.5">
                  <div class="flex items-center gap-2 text-[10px]">
                    <svg class="w-3.5 h-3.5 text-emerald-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M5 13l4 4L19 7"/></svg>
                    <span class="text-slate-300">Mon–Wed rates <span class="text-red-400 line-through">$120</span> → <span class="text-teal-400 font-semibold">$99</span></span>
                  </div>
                  <div class="flex items-center gap-2 text-[10px]">
                    <svg class="w-3.5 h-3.5 text-emerald-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M5 13l4 4L19 7"/></svg>
                    <span class="text-slate-300">Fri–Sat rates <span class="text-slate-400">$120</span> → <span class="text-teal-400 font-semibold">$175</span></span>
                  </div>
                  <div class="flex items-center gap-2 text-[10px]">
                    <svg class="w-3.5 h-3.5 text-emerald-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M5 13l4 4L19 7"/></svg>
                    <span class="text-slate-300">2-night minimum discount: <span class="text-teal-400 font-semibold">-10%</span></span>
                  </div>
                </div>
              </div>
            </div>
            <div class="flex justify-start">
              <div class="rounded-xl rounded-bl-sm bg-white/5 border border-white/10 px-3 py-2 max-w-[75%]">
                <p class="text-[11px] text-slate-300 leading-relaxed">Synced to all channels. Landlord report updated.</p>
                <div class="mt-1.5 flex gap-1.5">
                  <span class="px-1.5 py-0.5 rounded bg-teal-500/20 text-[8px] text-teal-400">Booking.com ✓</span>
                  <span class="px-1.5 py-0.5 rounded bg-teal-500/20 text-[8px] text-teal-400">Airbnb ✓</span>
                  <span class="px-1.5 py-0.5 rounded bg-teal-500/20 text-[8px] text-teal-400">VRBO ✓</span>
                </div>
              </div>
            </div>
          </div>
          <div class="px-4 pb-4">
            <div class="flex items-center gap-2 rounded-xl bg-white/5 border border-white/10 px-3 py-2.5">
              <p class="text-[11px] text-slate-500 flex-1">Ask Hostbase AI anything...</p>
              <div class="w-6 h-6 rounded-lg bg-teal-500/30 flex items-center justify-center">
                <svg class="w-3 h-3 text-teal-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"/></svg>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Panel 3: Landlord View -->
      <div class="hero-panel hero-panel-3" data-id="3" style="display:none;">
        <div class="rounded-2xl border border-white/10 bg-[#0d1525]/90 backdrop-blur-md shadow-2xl shadow-black/30 overflow-hidden">
          <div class="flex items-center gap-2 px-5 py-3 bg-white/5 border-b border-white/10">
            <div class="flex gap-1.5">
              <div class="w-2.5 h-2.5 rounded-full bg-red-400/60"></div>
              <div class="w-2.5 h-2.5 rounded-full bg-yellow-400/60"></div>
              <div class="w-2.5 h-2.5 rounded-full bg-green-400/60"></div>
            </div>
            <div class="flex-1 flex justify-center">
              <div class="px-3 py-0.5 rounded-md bg-amber-500/10 border border-amber-500/20 text-[10px] text-amber-400 font-medium">Landlord Portal</div>
            </div>
          </div>
          <div class="p-6">
            <div class="mb-5">
              <p class="text-xs text-slate-500 mb-1">Property Owner Statement — April 2026</p>
              <p class="text-sm font-semibold text-white">Sunset Villa, Dubai Marina</p>
            </div>
            <div class="grid grid-cols-3 gap-4 mb-5">
              <div class="rounded-lg bg-white/5 border border-white/10 p-3 text-center">
                <p class="text-[9px] text-slate-500">Nights Booked</p>
                <p class="text-xl font-bold text-white">22</p>
                <p class="text-[9px] text-slate-400">of 30</p>
              </div>
              <div class="rounded-lg bg-white/5 border border-white/10 p-3 text-center">
                <p class="text-[9px] text-slate-500">Gross Revenue</p>
                <p class="text-xl font-bold text-white">$8,420</p>
                <p class="text-[9px] text-teal-400">+18% vs Mar</p>
              </div>
              <div class="rounded-lg bg-white/5 border border-white/10 p-3 text-center">
                <p class="text-[9px] text-slate-500">Net Payout</p>
                <p class="text-xl font-bold text-emerald-400">$6,577</p>
                <p class="text-[9px] text-teal-400">+22% vs Mar</p>
              </div>
            </div>
            <div class="rounded-lg bg-white/5 border border-white/10 p-4">
              <p class="text-[10px] text-slate-400 font-medium mb-3">Breakdown</p>
              <div class="space-y-2">
                <div class="flex justify-between text-[10px]">
                  <span class="text-slate-300">Accommodation revenue</span>
                  <span class="text-white font-medium">$7,260</span>
                </div>
                <div class="flex justify-between text-[10px]">
                  <span class="text-slate-300">Cleaning fees</span>
                  <span class="text-white font-medium">$1,160</span>
                </div>
                <div class="flex justify-between text-[10px]">
                  <span class="text-slate-400">Management fee (15%)</span>
                  <span class="text-red-400 font-medium">-$1,263</span>
                </div>
                <div class="flex justify-between text-[10px]">
                  <span class="text-slate-400">Maintenance & supplies</span>
                  <span class="text-red-400 font-medium">-$580</span>
                </div>
                <div class="border-t border-white/10 pt-2 flex justify-between text-[11px]">
                  <span class="text-white font-semibold">Owner payout</span>
                  <span class="text-emerald-400 font-bold">$6,577</span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero-headline {
    font-family: 'Libre Baskerville', 'Georgia', serif;
    letter-spacing: -0.02em;
  }

  .hero-gradient-text {
    background: linear-gradient(135deg, #0097A7, #00BCD4, #0097A7);
    background-size: 200% 200%;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    animation: gradient-shift 6s ease-in-out infinite;
  }

  @keyframes gradient-shift {
    0%, 100% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
  }

  /* Stars */
  .star {
    position: absolute;
    width: var(--size);
    height: var(--size);
    background: white;
    border-radius: 50%;
    animation: twinkle var(--duration) ease-in-out var(--delay) infinite;
  }

  @keyframes twinkle {
    0%, 100% { opacity: 0.2; transform: scale(1); }
    50% { opacity: 0.9; transform: scale(1.3); }
  }

  /* Sparkle stars */
  .sparkle {
    position: absolute;
    width: 4px;
    height: 4px;
    animation: sparkle-anim var(--duration) ease-in-out var(--delay) infinite;
  }

  .sparkle::before,
  .sparkle::after {
    content: '';
    position: absolute;
    background: white;
    border-radius: 1px;
  }

  .sparkle::before {
    width: 1px;
    height: 100%;
    left: 50%;
    top: 0;
    transform: translateX(-50%);
  }

  .sparkle::after {
    width: 100%;
    height: 1px;
    top: 50%;
    left: 0;
    transform: translateY(-50%);
  }

  @keyframes sparkle-anim {
    0%, 100% { opacity: 0; transform: scale(0.5) rotate(0deg); }
    25% { opacity: 0; }
    50% { opacity: 1; transform: scale(1.2) rotate(45deg); }
    75% { opacity: 0; }
  }

  /* Hero tabs */
  .hero-tab-btn {
    color: rgba(148, 163, 184, 0.6);
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.05);
  }
  .hero-tab-btn.active {
    color: #2dd4bf;
    background: rgba(45, 212, 191, 0.1);
    border-color: rgba(45, 212, 191, 0.2);
  }
  .hero-tab-btn:hover:not(.active) {
    color: rgba(148, 163, 184, 0.9);
    background: rgba(255, 255, 255, 0.05);
  }

  @keyframes hero-panel-enter {
    from { opacity: 0; transform: translateY(20px) scale(0.97); }
    to { opacity: 1; transform: translateY(0) scale(1); }
  }

  .hero-bar {
    animation: hero-bar-grow 0.5s ease-out both;
    transform-origin: bottom;
  }

  @keyframes hero-bar-grow {
    from { transform: scaleY(0); }
    to { transform: scaleY(1); }
  }

  .hero-occupancy-bar {
    width: 0;
    animation: hero-fill-occ 1.2s ease-out 0.8s forwards;
  }

  @keyframes hero-fill-occ {
    to { width: 92%; }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const buttons = document.querySelectorAll('.hero-tab-btn');
    const panels = document.querySelectorAll('.hero-panel');

    buttons.forEach(btn => {
      btn.addEventListener('click', () => {
        const target = btn.getAttribute('data-panel');

        buttons.forEach(b => b.classList.remove('active'));
        btn.classList.add('active');

        panels.forEach(p => {
          p.style.display = 'none';
          p.style.opacity = '0';
        });

        const panel = document.querySelector(`.hero-panel-${target}`);
        if (panel) {
          panel.style.display = 'block';
          panel.style.animation = 'none';
          panel.offsetHeight;
          panel.style.animation = 'hero-panel-enter 0.5s ease-out forwards';
        }
      });
    });
  });
</script>
