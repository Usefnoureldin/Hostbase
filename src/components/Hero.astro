---
---
<section class="relative pt-32 pb-20 md:pt-40 md:pb-28 overflow-hidden">
  <!-- Background gradient -->
  <div class="absolute inset-0 bg-gradient-to-b from-teal-50/60 via-white to-white -z-10"></div>
  <div class="absolute top-20 left-1/2 -translate-x-1/2 w-[800px] h-[600px] bg-primary/5 rounded-full blur-3xl -z-10"></div>

  <div class="max-w-6xl mx-auto px-6 text-center">
    <!-- Badge -->
    <div class="animate-fade-in-up inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-primary/10 text-primary text-sm font-medium mb-8">
      <span class="w-1.5 h-1.5 rounded-full bg-primary animate-pulse"></span>
      Built for STR operators
    </div>

    <!-- Headline -->
    <h1 class="animate-fade-in-up delay-100 text-4xl md:text-6xl lg:text-7xl font-bold tracking-tight text-text leading-[1.1] max-w-4xl mx-auto">
      Your brand.
      <span class="text-primary">Your PMS.</span>
      <br />Zero complexity.
    </h1>

    <!-- Subheadline -->
    <p class="animate-fade-in-up delay-200 mt-6 text-lg md:text-xl text-text-muted max-w-2xl mx-auto leading-relaxed">
      White-label property management for short-term rental operators.
      Channel management, OTA distribution, and guest communications — all under your brand.
    </p>

    <!-- CTAs -->
    <div class="animate-fade-in-up delay-300 mt-10 flex flex-col sm:flex-row items-center justify-center gap-4">
      <a
        href="#demo"
        class="inline-flex items-center gap-2 px-7 py-3.5 bg-primary text-white font-medium rounded-xl hover:bg-primary-dark transition-all shadow-lg shadow-primary/25 hover:shadow-xl hover:shadow-primary/30 hover:-translate-y-0.5"
      >
        Book a Demo
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
          <path d="M6 3l5 5-5 5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
      <a
        href="#features"
        class="inline-flex items-center gap-2 px-7 py-3.5 bg-white text-text font-medium rounded-xl border border-border hover:border-primary/30 hover:bg-surface-alt transition-all"
      >
        See how it works
      </a>
    </div>

    <!-- Hero visual: Dashboard mockup -->
    <div class="animate-fade-in-up delay-500 mt-16 md:mt-20 max-w-4xl mx-auto">
      <div class="relative rounded-2xl border border-border bg-white shadow-2xl shadow-black/5 overflow-hidden">
        <!-- Browser bar -->
        <div class="flex items-center gap-2 px-4 py-3 bg-surface-alt border-b border-border">
          <div class="flex gap-1.5">
            <div class="w-3 h-3 rounded-full bg-red-400/80"></div>
            <div class="w-3 h-3 rounded-full bg-yellow-400/80"></div>
            <div class="w-3 h-3 rounded-full bg-green-400/80"></div>
          </div>
          <div class="flex-1 flex justify-center">
            <div class="px-4 py-1 rounded-md bg-white border border-border text-xs text-text-muted">yourbrand.hostbase.ai</div>
          </div>
        </div>
        <!-- Dashboard content -->
        <div class="p-6 md:p-8 bg-gradient-to-br from-surface-alt to-white">
          <div class="grid grid-cols-3 gap-4 mb-6">
            <div class="rounded-xl bg-white border border-border p-4 shadow-sm">
              <p class="text-xs text-text-muted mb-1">Occupancy</p>
              <p class="text-2xl font-bold text-text">87%</p>
              <p class="text-xs text-green-600 mt-1">+12% vs last month</p>
            </div>
            <div class="rounded-xl bg-white border border-border p-4 shadow-sm">
              <p class="text-xs text-text-muted mb-1">Revenue</p>
              <p class="text-2xl font-bold text-text">$24.8K</p>
              <p class="text-xs text-green-600 mt-1">+8% vs last month</p>
            </div>
            <div class="rounded-xl bg-white border border-border p-4 shadow-sm">
              <p class="text-xs text-text-muted mb-1">Bookings</p>
              <p class="text-2xl font-bold text-text">142</p>
              <p class="text-xs text-green-600 mt-1">+23 new this week</p>
            </div>
          </div>
          <!-- Calendar mockup -->
          <div class="rounded-xl bg-white border border-border p-4 shadow-sm">
            <div class="flex items-center justify-between mb-4">
              <p class="text-sm font-medium text-text">Calendar</p>
              <p class="text-xs text-text-muted">April 2026</p>
            </div>
            <div class="grid grid-cols-7 gap-1">
              {['Mon','Tue','Wed','Thu','Fri','Sat','Sun'].map(d => (
                <div class="text-center text-[10px] text-text-muted py-1">{d}</div>
              ))}
              {Array.from({length: 30}, (_, i) => i + 1).map(day => {
                const booked = [2,3,4,5,8,9,10,14,15,16,17,18,21,22,23,24,25,28,29,30].includes(day);
                return (
                  <div class={`text-center text-[11px] py-1.5 rounded-md ${booked ? 'bg-primary/15 text-primary font-medium' : 'text-text-muted'}`}>
                    {day}
                  </div>
                );
              })}
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
